{
  "name": "free-cut",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Free, open-source silence remover for video and audio",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently -n vite,electron \"vite dev\" \"tsc -p electron/tsconfig.json && wait-on http://localhost:5173 && electron dist/main.js\"",
    "dev:web": "vite dev",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "package": "pnpm build && electron-builder --config electron-builder.config.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "electron-serve": "^2.1.1",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.3",
    "wavesurfer.js": "^7.9.0"
  },
  "author": "Roman",
  "license": "MIT"
}
